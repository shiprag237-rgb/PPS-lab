# Phone Number Database using Dictionary

contacts = {}

n = int(input())

for _ in range(n):
    command = input().split()

    if command[0] == "ADD":
        name = command[1]
        phone = command[2]
        contacts[name] = phone   # Add or update

    elif command[0] == "REMOVE":
        name = command[1]
        if name in contacts:
            del contacts[name]

    elif command[0] == "DISPLAY":
        if not contacts:
            print("No contacts")
        else:
            for name in sorted(contacts):
                print(f"{name}: {contacts[name]}")
