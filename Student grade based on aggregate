# Input marks for four subjects
marks = list(map(int, input().split()))

# Calculate total
total = sum(marks)

# Calculate percentage
percentage = total / 4

# Determine grade
if percentage > 75:
    grade = "Distinction"
elif percentage >= 60:
    grade = "First Division"
elif percentage >= 50:
    grade = "Second Division"
elif percentage >= 40:
    grade = "Third Division"
else:
    grade = "Fail"

# Output
print(total)
print(f"{percentage:.2f}")
print(grade)
